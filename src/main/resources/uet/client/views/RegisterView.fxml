<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="550.0" prefWidth="400.0" spacing="15.0" 
      style="-fx-background-color: #2c3e50" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="uet.client.controllers.authController.RegisterController">
   <children>
      
      <Label text="ĐĂNG KÝ TÀI KHOẢN" textFill="WHITE">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Label>

      <TextField fx:id="usernameField" maxWidth="250.0" prefHeight="35.0" promptText="Tên đăng nhập" 
                 style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #aaaaaa;" />
      
      <TextField fx:id="emailField" maxWidth="250.0" prefHeight="35.0" promptText="Email" 
                 style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #aaaaaa;" />
      <StackPane alignment="CENTER_RIGHT" maxWidth="250.0"> 
         <TextField fx:id="visiblePasswordField" promptText="Nhập mật khẩu" visible="false" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #aaaaaa; -fx-pref-height: 35px; -fx-padding: 0 50 0 10;"/>
         <PasswordField fx:id="hiddenPasswordField" promptText="Nhập mật khẩu" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #aaaaaa; -fx-pref-height: 35px; -fx-padding: 0 50 0 10;"/>
         <Button fx:id="togglePasswordBtn" mnemonicParsing="false" onAction="#togglePassword" text="HIỆN" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>
      </StackPane>
      <StackPane alignment="CENTER_RIGHT" maxWidth="250.0"> 
         <TextField fx:id="visibleConfirmPasswordField" promptText="Nhập lại mật khẩu" visible="false" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #aaaaaa; -fx-pref-height: 35px; -fx-padding: 0 50 0 10;"/>
         <PasswordField fx:id="hiddenConfirmPasswordField" promptText="Nhập lại mật khẩu" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #aaaaaa; -fx-pref-height: 35px; -fx-padding: 0 50 0 10;"/>
         <Button fx:id="toggleConfirmPasswordBtn" mnemonicParsing="false" onAction="#toggleConfirmPassword" text="HIỆN" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-weight: bold; -fx-text-fill: #aaaaaa;"/>
      </StackPane>
                     
      <ComboBox fx:id="roleComboBox" maxWidth="250.0" prefHeight="35.0" promptText="Chọn vai trò" 
                style="-fx-background-color: #333333; -fx-background-radius: 5; -fx-cursor: hand;" />
                
      <VBox alignment="CENTER_LEFT" maxWidth="250.0" spacing="5.0">
         <children>     
            <DatePicker fx:id="dobPicker" prefHeight="35.0" prefWidth="250.0" promptText="Chọn ngày tháng năm sinh" 
                        style="-fx-cursor: hand; -fx-control-inner-background: #333333; -fx-prompt-text-fill: #aaaaaa; -fx-text-fill: white;" />
         </children>
      </VBox>
      <Button mnemonicParsing="false" onAction="#handleRegister" prefHeight="40.0" prefWidth="250.0" 
              style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" 
              text="Xác nhận đăng ký">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      
      <HBox alignment="CENTER" spacing="5.0">
         <children>
            <Label text="Đã có tài khoản?" textFill="#aaaaaa" />
            <Hyperlink onAction="#switchLogin" 
                       style="-fx-text-fill: white; -fx-font-weight: bold; -fx-border-color: transparent; -fx-underline: false;" 
                       text="Quay lại đăng nhập" />
         </children>
      </HBox>
      <Label fx:id="note" textFill="#e74c3c">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </Label>
   </children>
   <padding>
      <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
   </padding>
</VBox>