<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="800.0" spacing="30.0" style="-fx-background-color: #2c3e50;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uet.client.controllers.bidderController.AutoBidController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>
        <Label text="TỰ ĐỘNG ĐẤU GIÁ" textFill="WHITE">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label text="Vui lòng đưa ra mức giá cao hơn giá hiện tại để giành quyền mua sản phẩm" textFill="#bdc3c7">
            <font>
                <Font size="14.0" />
            </font>
        </Label>

        <VBox maxWidth="500.0" spacing="25.0" style="-fx-background-color: #34495e; -fx-background-radius: 10; -fx-padding: 30;">
            <children>

                <VBox spacing="10.0">
                    <children>
                  <Label text="Nhập giá tối đa" textFill="#dfe709" />
                        <TextField fx:id="maxBid" prefHeight="45.0" promptText="Nhập giá tối đa" style="-fx-background-color: #ecf0f1; -fx-font-size: 16px; -fx-background-radius: 5;" />
                    </children>
                </VBox>
            <Label text="Nhập Bước giá" textFill="#ead856" />
            <TextField fx:id="increment" prefHeight="45.0" promptText="Nhập Bước giá" style="-fx-background-color: #ecf0f1; -fx-font-size: 16px; -fx-background-radius: 5;" />
            </children>
        </VBox>
      <Label fx:id="noteLabel" text="Note" textFill="#e40e0e" />

        <HBox alignment="CENTER" spacing="30.0">
            <children>
                <Button mnemonicParsing="false" onAction="#backBidview" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14px;" text="Quay lại" />
                <Button mnemonicParsing="false" onAction="#handlerAutoBid" prefHeight="45.0" prefWidth="180.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 14px;" text="Xác nhận Bật tự đặt giá" />
            </children>
            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
