<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="250.0" prefWidth="350.0" spacing="15.0" 
      style="-fx-background-color: #34495e; -fx-border-color: #2c3e50; -fx-border-width: 2;" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="uet.client.controllers.BidDialogController">
   <children>
      <Label text="THAM GIA ĐẤU GIÁ" textFill="WHITE">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <Label fx:id="productNameLabel" text="Sản phẩm: ..." textFill="#ecf0f1">
         <font><Font size="14.0" /></font>
      </Label>
      
      <Label fx:id="currentPriceLabel" text="Giá hiện tại: $..." textFill="#f1c40f">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>

      <TextField fx:id="bidAmountField" maxWidth="200.0" prefHeight="35.0" promptText="Nhập giá bạn muốn đặt ($)" 
                 style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #95a5a6;" />

      <Label fx:id="errorLabel" textFill="#e74c3c">
         <font><Font name="System Italic" size="12.0" /></font>
      </Label>

      <HBox alignment="CENTER" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleConfirm" prefHeight="35.0" prefWidth="100.0" 
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-font-weight: bold;" 
                    text="Xác nhận" />
            <Button mnemonicParsing="false" onAction="#handleCancel" prefHeight="35.0" prefWidth="100.0" 
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5; -fx-font-weight: bold;" 
                    text="Hủy" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>