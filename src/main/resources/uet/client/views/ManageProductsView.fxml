<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="900.0" spacing="20.0" style="-fx-background-color: #2c3e50;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uet.client.controllers.ManageProductsController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
   <children>
      <Label text="DANH SÁCH SẢN PHẨM ĐÃ LÊN SÀN" textFill="WHITE">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      
      <Label text="Theo dõi tiến độ và giá đấu của các phiên bạn đã tạo" textFill="#bdc3c7" />

      <TableView fx:id="productTable" prefHeight="400.0" prefWidth="840.0" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="itemCodeCol" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Mã SP (ID)" />
          <TableColumn fx:id="nameCol" prefWidth="180.0" text="Tên Sản Phẩm" />
          <TableColumn fx:id="highestBidCol" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;" text="Giá Cao Nhất ($)" />
          <TableColumn fx:id="statusCol" prefWidth="110.0" style="-fx-alignment: CENTER;" text="Trạng Thái" />
          <TableColumn fx:id="actionCol" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Thao Tác" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

      <HBox alignment="CENTER_RIGHT" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Quay lại Dashboard" />
            <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Làm mới dữ liệu" />
         </children>
      </HBox>
   </children>
</VBox>
