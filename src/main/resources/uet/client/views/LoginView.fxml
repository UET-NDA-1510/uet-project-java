<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="400.0" spacing="20.0" style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uet.client.controllers.LoginController">
   <children>
      
      <Label text="HỆ THỐNG ĐẤU GIÁ" textFill="WHITE">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      
      <TextField fx:id="usernameField" maxWidth="250.0" prefHeight="35.0" promptText="Tên đăng nhập" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #aaaaaa;" />
      
      <PasswordField fx:id="passwordField" maxWidth="250.0" prefHeight="35.0" promptText="Mật khẩu" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-background-radius: 5; -fx-prompt-text-fill: #aaaaaa;" />
      
      <ComboBox fx:id="roleComboBox" maxWidth="250.0" prefHeight="35.0" promptText="Chọn vai trò" style="-fx-background-color: #333333; -fx-background-radius: 5;" />
      
      <Button mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;" text="Đăng nhập">
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      
      <HBox alignment="CENTER" spacing="5.0">
         <children>
            <Label text="Bạn chưa có tài khoản?" textFill="#aaaaaa" />
            <Hyperlink onAction="#switchRegister" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-border-color: transparent; -fx-underline: false;" text="Đăng ký ngay" />
         </children>
      </HBox>
      <Label fx:id="note" textFill="#f1c40f">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </Label>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
