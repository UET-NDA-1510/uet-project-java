<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="550.0" prefWidth="500.0" spacing="0.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uet.client.controllers.AccountInfoController">
    <children>
        
        <VBox alignment="CENTER" prefHeight="130.0" spacing="5.0" style="-fx-background-color: #2c3e50;">
            <children>
                <Label text="HỒ SƠ CÁ NHÂN" textFill="WHITE">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <Label fx:id="roleLabel" text="Vai trò: Đang tải..." textFill="#3498db">
                    <font><Font name="System Bold" size="12.0" /></font>
                </Label>
            </children>
            <padding><Insets bottom="10.0" top="10.0" /></padding>
        </VBox>

        <VBox spacing="0.0" VBox.vgrow="ALWAYS">
            <padding><Insets bottom="20.0" left="30.0" right="30.0" top="15.0" /></padding>
            <children>
                
                <HBox alignment="CENTER_LEFT" prefHeight="45.0">
                    <Label prefWidth="120.0" text="Mã định danh:" textFill="#7f8c8d"><font><Font name="System Bold" size="13.0" /></font></Label>
                    <Label fx:id="idLabel" text="..." textFill="#2c3e50"><font><Font name="System Bold" size="14.0" /></font></Label>
                </HBox>
                <Separator />

                <HBox alignment="CENTER_LEFT" prefHeight="45.0">
                    <Label prefWidth="120.0" text="Tên đăng nhập:" textFill="#7f8c8d"><font><Font name="System Bold" size="13.0" /></font></Label>
                    <Label fx:id="usernameLabel" text="..." textFill="#2c3e50"><font><Font name="System Bold" size="14.0" /></font></Label>
                </HBox>
                <Separator />

                <HBox alignment="CENTER_LEFT" prefHeight="45.0">
                    <Label prefWidth="120.0" text="Địa chỉ Email:" textFill="#7f8c8d"><font><Font name="System Bold" size="13.0" /></font></Label>
                    <Label fx:id="emailLabel" text="..." textFill="#2c3e50"><font><Font name="System Bold" size="14.0" /></font></Label>
                </HBox>
                <Separator />

                <HBox alignment="CENTER_LEFT" prefHeight="45.0">
                    <Label prefWidth="120.0" text="Ngày sinh nhật:" textFill="#7f8c8d"><font><Font name="System Bold" size="13.0" /></font></Label>
                    <Label fx:id="dobLabel" text="..." textFill="#2c3e50"><font><Font name="System Bold" size="14.0" /></font></Label>
                </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="45.0">
               <children>
                  <Label fx:id="other" prefWidth="120.0" text="Trận thắng" textFill="#7f8c8d">
                     <font>
                        <Font name="System Bold" size="13.0" />
                     </font>
                  </Label>
                  <Label fx:id="total_win" text="..." textFill="#2c3e50">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
               </children>
            </HBox>

                <Region prefHeight="15.0" />

                <HBox alignment="CENTER_LEFT" prefHeight="55.0" style="-fx-background-color: #e8f8f5; -fx-background-radius: 8; -fx-border-color: #2ecc71; -fx-border-radius: 8; -fx-border-width: 1;">
                    <padding><Insets left="15.0" right="15.0" /></padding>
                    <children>
                        <Label prefWidth="105.0" text="Số dư khả dụng:" textFill="#27ae60"><font><Font name="System Bold" size="13.0" /></font></Label>
                        <Label fx:id="balanceLabel" text="..." textFill="#27ae60"><font><Font name="System Bold" size="18.0" /></font></Label>
                    </children>
                </HBox>

            </children>
        </VBox>

        <HBox alignment="CENTER" prefHeight="65.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #ecf0f1; -fx-border-width: 1 0 0 0;">
            <children>
                <Button mnemonicParsing="false" onAction="#handleBack" prefHeight="38.0" prefWidth="140.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 20;" text="QUAY LẠI">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
            </children>
        </HBox>

    </children>
</VBox>
